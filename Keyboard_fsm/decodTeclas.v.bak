module decodTeclas (
    input      [3:0] key_in,
    input            push_button, // solo valida el codigo mientras dure el pulso de push_button
    output reg       Aceptar,
    output reg       Borrar,
    output reg       Salir
);

    always @(*) begin
      
        Aceptar = 1'b0;
        Borrar  = 1'b0;
        Salir   = 1'b0;

    
        if (push_button) begin
            if (key_in == 4'd10)
                Aceptar = 1'b1; // tecla 'A'
            else if (key_in == 4'd11)
                Borrar = 1'b1;  // tecla 'B'
            else if (key_in == 4'd14)
                Salir = 1'b1;   // tecla '*'
        end
    end

endmodule