module top (
    input clk, reset,
    input [3:0] col,

    output [3:0] row,
    output [3:0] key_out
);

wire count, clk1, contar, count;
wire [2:0] row_reg;
wire [3:0] key_in, col_reg;
wire scan, delay, decoder;
wire esperar, decodificar;

clock clk_div (
    .clk(clk),
    .reset(reset),
    .count(clk1)
);

counter c2 (
        .clk(clk1),
        .contar(contar),
        .reset(reset),
        .count(count)
    );


Matrix_4x4 mat1 (
    .counter(count),
    .col_in(col),
    .value_detected(scan),
    .row_out(row),
    .col_reg(col_reg),
    .row_reg(row_reg)
);



decodificador dec (
    .clk(clk1),
    .reset(reset),
    .row_reg(row_reg),
    .col_cleaned(col_reg),
    .decodificar(decodificar),
    .decoder(decoder),
    .salida(key_in)
);

debounce db (
    .clk(clk1),
    .reset(reset),
    .key_in(key_in),
    .esperar(esperar),
    .delay(delay),
    .key_out(key_out)
);

FSM_teclado fsm (
    .clk(count),
    .reset(reset),

    .scan(scan),
    .decoder(decoder),
    .delay(delay),

    .contar(contar),
    .decodificar(decodificar),
    .esperar(esperar)
);

endmodule